      <aliases enabled='yes' />
      <column datatype='string' name='[:Measure Names]' role='dimension' type='nominal'>
        <aliases>
          <alias key='&quot;[federated.1bcotxt020xplc1edf1ng1th6ws9].[sum:Goals:qk]&quot;' value='Goals scored by Top scorer' />
          <alias key='&quot;[federated.1bcotxt020xplc1edf1ng1th6ws9].[sum:Total_Goals:qk]&quot;' value='Total Goals in tournament' />
        </aliases>
      </column>
      <column caption='match date' datatype='date' name='[Calculation_2463299012067330]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='// Match Date (for Gantt positioning)&#10;MAKEDATE([Year], 7, 15)  // Using July 15th as approximate final date' />
      </column>
      <column caption='Winning Country' datatype='string' name='[Calculation_2463299357839363]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CASE [Winner]&#10;    // Germany grouping&#10;    WHEN &quot;West Germany&quot; THEN &quot;Germany&quot;&#10;    WHEN &quot;Germany&quot; THEN &quot;Germany&quot;&#10;    &#10;&#10;    WHEN &quot;Soviet Union&quot; THEN &quot;Russia&quot;  &#10;    WHEN &quot;Czechoslovakia&quot; THEN &quot;Czech Republic&quot;  &#10;    &#10;    // Default: keep original name&#10;    ELSE [Winner]&#10;END' />
      </column>
      <column caption='Runner- up country' datatype='string' name='[Calculation_2463299359305732]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CASE [Runner_Up]&#10;&#10;    WHEN &quot;West Germany&quot; THEN &quot;Germany&quot;&#10;    WHEN &quot;Germany&quot; THEN &quot;Germany&quot;&#10;   &#10;   &#10;    WHEN &quot;Soviet Union&quot; THEN &quot;Russia&quot;  // Example if you want to group USSR/Russia&#10;    WHEN &quot;Czechoslovakia&quot; THEN &quot;Czech Republic&quot;  // Historical grouping example&#10;    &#10;    // Default: keep original name&#10;    ELSE [Runner_Up]&#10;END' />
      </column>
      <column caption='WinCount' datatype='integer' name='[Calculation_2463299359563781]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='// Total Wins (Aggregated)&#10;{FIXED [Calculation_2463299357839363] : COUNTD([Year])}' />
      </column>
      <column caption='Years Won' datatype='string' name='[Calculation_2463299365613574]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='{ FIXED [Calculation_2463299357839363] : &#10;    MAX(&#10;        // Germany/West Germany special case&#10;        IF ([Winner] = &quot;West Germany&quot; AND [Calculation_2463299357839363] = &quot;Germany&quot;) &#10;           OR ([Winner] = &quot;Germany&quot; AND [Calculation_2463299357839363] = &quot;Germany&quot;)&#10;        THEN &quot;1954, 1974, 1990, 2014&quot;&#10;        &#10;&#10;        ELSEIF [Winner] = &quot;Brazil&quot; AND [Calculation_2463299357839363] = &quot;Brazil&quot;&#10;        THEN &quot;1958, 1962, 1970, 1994, 2002&quot;&#10;        &#10;&#10;        ELSEIF [Winner] = &quot;Italy&quot; AND [Calculation_2463299357839363] = &quot;Italy&quot;&#10;        THEN &quot;1934, 1938, 1982, 2006&quot;&#10;        &#10;        ELSEIF [Winner] = &quot;Argentina&quot; AND [Calculation_2463299357839363] = &quot;Argentina&quot;&#10;        THEN &quot;1978, 1986, 2022&quot;&#10;        &#10;        ELSEIF [Winner] = &quot;France&quot; AND [Calculation_2463299357839363] = &quot;France&quot;&#10;        THEN &quot;1998, 2018&quot;&#10;        &#10;        ELSEIF [Winner] = &quot;Uruguay&quot; AND [Calculation_2463299357839363] = &quot;Uruguay&quot;&#10;        THEN &quot;1930, 1950&quot;&#10;        &#10;        ELSEIF [Winner] = &quot;England&quot; AND [Calculation_2463299357839363] = &quot;England&quot;&#10;        THEN &quot;1966&quot;&#10;        &#10;        ELSEIF [Winner] = &quot;Spain&quot; AND [Calculation_2463299357839363] = &quot;Spain&quot;&#10;        THEN &quot;2010&quot;&#10;        &#10;        ELSE &quot;&quot;&#10;        END&#10;    )&#10;}' />
      </column>
      <column caption='RunnerUp Count' datatype='integer' name='[Calculation_2463299369291783]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='// Total runner up Wins (Aggregated)&#10;{FIXED [Calculation_2463299359305732] : COUNTD([Year])}' />
      </column>
      <column datatype='string' name='[Country]' role='dimension' semantic-role='[Country].[ISO3166_2]' type='nominal' />
      <column caption='Fourth Place' datatype='string' name='[Fourth_Place]' role='dimension' type='nominal' />
      <column datatype='integer' name='[Goals]' role='measure' type='quantitative' />
      <column caption='Goals Per Match' datatype='real' name='[Goals_Per_Match]' role='measure' type='quantitative' />
