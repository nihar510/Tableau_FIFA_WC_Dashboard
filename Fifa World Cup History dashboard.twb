      <table>
        <view>
          <datasources>
            <datasource caption='fifa_world_cup_history' name='federated.1bcotxt020xplc1edf1ng1th6ws9' />
          </datasources>
          <datasource-dependencies datasource='federated.1bcotxt020xplc1edf1ng1th6ws9'>
            <column caption='Winning Country' datatype='string' name='[Calculation_2463299357839363]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='CASE [Winner]&#10;    // Germany grouping&#10;    WHEN &quot;West Germany&quot; THEN &quot;Germany&quot;&#10;    WHEN &quot;Germany&quot; THEN &quot;Germany&quot;&#10;    &#10;&#10;    WHEN &quot;Soviet Union&quot; THEN &quot;Russia&quot;  &#10;    WHEN &quot;Czechoslovakia&quot; THEN &quot;Czech Republic&quot;  &#10;    &#10;    // Default: keep original name&#10;    ELSE [Winner]&#10;END' />
            </column>
            <column caption='Runner- up country' datatype='string' name='[Calculation_2463299359305732]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='CASE [Runner_Up]&#10;&#10;    WHEN &quot;West Germany&quot; THEN &quot;Germany&quot;&#10;    WHEN &quot;Germany&quot; THEN &quot;Germany&quot;&#10;   &#10;   &#10;    WHEN &quot;Soviet Union&quot; THEN &quot;Russia&quot;  // Example if you want to group USSR/Russia&#10;    WHEN &quot;Czechoslovakia&quot; THEN &quot;Czech Republic&quot;  // Historical grouping example&#10;    &#10;    // Default: keep original name&#10;    ELSE [Runner_Up]&#10;END' />
            </column>
            <column caption='RunnerUp Count' datatype='integer' name='[Calculation_2463299369291783]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='// Total runner up Wins (Aggregated)&#10;{FIXED [Calculation_2463299359305732] : COUNTD([Year])}' />
            </column>
            <column caption='Runner Up' datatype='string' name='[Runner_Up]' role='dimension' type='nominal' />
            <column datatype='string' name='[Winner]' role='dimension' type='nominal' />
            <column datatype='integer' name='[Year]' role='dimension' type='quantitative' />
            <column caption='Runner up Years ' datatype='string' name='[Years Won (copy)_2463299371716616]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='// Runner-Up Years Complete&#10;{ FIXED [Calculation_2463299359305732] : &#10;    MAX(&#10;        // Germany/West Germany runner-up years&#10;        IF ([Calculation_2463299359305732] = &quot;West Germany&quot;) &#10;           OR ([Calculation_2463299359305732] = &quot;Germany&quot; )&#10;        THEN &quot;1966, 1982, 1986, 2002&quot;&#10;        &#10;        // Brazil runner-up years&#10;        ELSEIF [Calculation_2463299359305732] = &quot;Brazil&quot; &#10;        THEN &quot;1950, 1998&quot;&#10;        &#10;        // Italy runner-up years&#10;        ELSEIF [Calculation_2463299359305732] = &quot;Italy&quot; &#10;        THEN &quot;1970, 1994&quot;&#10;        &#10;        // Argentina runner-up years&#10;        ELSEIF [Calculation_2463299359305732] = &quot;Argentina&quot; &#10;        THEN &quot;1930, 1990, 2014&quot;&#10;        &#10;        // France runner-up years&#10;        ELSEIF [Calculation_2463299359305732] = &quot;France&quot; &#10;        THEN &quot;2006, 2022&quot;&#10;        &#10;        // Netherlands runner-up years&#10;        ELSEIF [Calculation_2463299359305732] = &quot;Netherlands&quot; &#10;        THEN &quot;1974, 1978, 2010&quot;&#10;        &#10;        // Hungary runner-up years&#10;        ELSEIF [Calculation_2463299359305732] = &quot;Hungary&quot; &#10;        THEN &quot;1938, 1954&quot;&#10;        &#10;        // Czechoslovakia runner-up years&#10;        ELSEIF [Calculation_2463299359305732]= &quot;Czechoslovakia&quot; &#10;        THEN &quot;1934, 1962&quot;&#10;        &#10;        // Sweden runner-up years&#10;        ELSEIF [Calculation_2463299359305732] = &quot;Sweden&quot; &#10;        THEN &quot;1958&quot;&#10;        &#10;        // Croatia runner-up years&#10;        ELSEIF [Calculation_2463299359305732] = &quot;Croatia&quot; &#10;        THEN &quot;2018&quot;        &#10;        ELSE &quot;&quot;&#10;        END&#10;    )&#10;}' />
            </column>
            <column-instance column='[Years Won (copy)_2463299371716616]' derivation='Attribute' name='[attr:Years Won (copy)_2463299371716616:nk]' pivot='key' type='nominal' />
