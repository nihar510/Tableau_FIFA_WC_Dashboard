      <column caption='Matches Played' datatype='integer' name='[Matches_Played]' role='measure' type='quantitative' />
      <column datatype='string' name='[Player]' role='dimension' type='nominal' />
      <column caption='Runner Up' datatype='string' name='[Runner_Up]' role='dimension' type='nominal' />
      <column caption='Third Place' datatype='string' name='[Third_Place]' role='dimension' type='nominal' />
      <column caption='Total Goals' datatype='integer' name='[Total_Goals]' role='measure' type='quantitative' />
      <column caption='Year (fifa world cup top scorers.csv)' datatype='integer' name='[Year (fifa_world_cup_top_scorers.csv)]' role='dimension' type='quantitative' />
